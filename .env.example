# Sof Mebel - Environment Variables Template
# Copy this to .env.local for development

# Next.js Public Variables (accessible in browser)
NEXT_PUBLIC_APP_NAME=Sof Mebel
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEBUG=false

# Optional: Analytics & Tracking
# NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id

# Optional: External Services
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# Private Variables (server-only, never exposed to browser)
# DATABASE_URL=
# API_SECRET_KEY=
